{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "preset": "superpowers-bridge",
  "disabled_agents": [],
  "showStartupToast": false,
  "presets": {
    "superpowers-bridge": {
      "orchestrator": {
        // Priority-ordered model fallback chain. ForegroundFallbackManager
        // (src/hooks/foreground-fallback) catches rate-limit / quota /
        // overload errors on the active model, aborts the stuck prompt,
        // and replays the last user message on the next model.
        // Within a session, after the first failover it sticks to the
        // fallback (no wasted opus retry on subsequent turns).
        "model": [
          { "id": "gauge-forge-anthropic/claude-opus-4-7", "variant": "high" },
          { "id": "gauge-forge-openai/gpt-5.4",            "variant": "xhigh" }
        ],
        "mcps": ["*", "!context7"]
      },
      // Fallback primary orchestrator for when claude-opus-4-7 hits the
      // 5-hour rate limit. Same MCPs and bridge prompt as orchestrator
      // (auto-inherited via isOrchestratorAgent() prefix matching), only
      // the model differs. Switch to it from the OpenCode agent picker.
      "orchestrator-beta": {
        "model": "gauge-forge-openai/gpt-5.4",
        "variant": "xhigh",
        "mcps": ["*", "!context7"]
      },
      // Manual GPT root with beta's operator posture, but without beta's
      // Claude-subagent fallback semantics.
      "orchestrator-delta": {
        "model": "gauge-forge-openai/gpt-5.4",
        "variant": "xhigh",
        "mcps": ["*", "!context7"]
      },
      "oracle": {
        "model": "gauge-forge-openai/gpt-5.5",
        "variant": "xhigh",
        "mcps": []
      },
      "librarian": {
        "model": [
          { "id": "gauge-forge-anthropic/claude-opus-4-7", "variant": "high" },
          { "id": "gauge-forge-openai/gpt-5.4",            "variant": "xhigh" }
        ],
        "mcps": ["websearch", "context7", "gh_grep"]
      },
      "explorer": {
        "model": "gauge-forge-openai/gpt-5.4",
        "variant": "medium",
        "mcps": []
      },
      "designer": {
        "model": "gauge-forge-openai/gpt-5.5",
        "variant": "high",
        "mcps": []
      },
      "fixer": {
        "model": "gauge-forge-openai/gpt-5.5",
        "variant": "high",
        "mcps": []
      },
      "laborer": {
        "model": "gauge-forge-openai/gpt-5.3-codex-spark",
        "variant": "high",
        "skills": [],
        "mcps": [],
        "prompt": "You are Laborer, an execution-focused coding worker. Your job is to carry out clearly scoped implementation tasks quickly and reliably. You can read code, edit files, run commands, and make normal code changes. Prefer direct execution over long analysis. Operate within the requested scope. Do not redesign architecture unless explicitly asked. Do not make strategic decisions when requirements are unclear. Do not take ownership of high-risk debugging or core technical judgment. When the task is ambiguous, conflicts with existing structure, or touches critical architecture, stop and hand it back to the orchestrator or fixer. Use local codebase tools first. Make concrete progress. Keep changes minimal and practical. Avoid delegation unless narrow reconnaissance is truly necessary; otherwise do the work yourself.",
        "orchestratorPrompt": "@laborer\n- Role: Fast execution worker for clearly scoped coding tasks and mechanical implementation work.\n- Delegate when: the task is concrete, bounded, and mostly execution-focused; examples include small-to-medium feature wiring, repetitive edits, straightforward refactors, boilerplate completion, config updates, file-by-file implementation, and carrying out an already-decided approach.\n- Don't delegate when: architecture is unclear, the bug is deep or unstable, the task affects core abstractions, the implementation requires major technical judgment, or you need a true senior engineer to choose the approach.\n- Escalate to @fixer when the task becomes core-system work, non-obvious debugging, risky refactoring, or design-sensitive implementation."
      },
      "observer": {
        "model": "gauge-forge-openai/gpt-5.5",
        "variant": "high",
        "mcps": []
      },
      "council": {
        "model": "gauge-forge-openai/gpt-5.4",
        "variant": "high",
        "mcps": []
      },
      "councillor": {
        "model": "openai/gpt-5.4-mini",
        "variant": "high",
        "mcps": []
      },

      // ============ Best-of-N variant agents (16) ============
      // Model + variant + per-variant orchestratorPrompt.
      // Behavioral contract (permission/hidden/mode) lives in agents/<name>.md.
      // Superpowers skill policy auto-inherited from base via
      // superpowers-policy.ts resolveBaseAgentName().

      "fixer-alpha": {
        "model": "gauge-forge-openai/gpt-5.5",
        "orchestratorPrompt": "@fixer-alpha\n- Best-of-N variant of @fixer. Model: gpt-5.5 (OpenAI flagship lane).\n- Dispatch ONLY via best-of-n-with-judge skill orchestration."
      },
      "fixer-beta": {
        "model": [
          { "id": "gauge-forge-anthropic/claude-opus-4-7", "variant": "high" },
          { "id": "gauge-forge-openai/gpt-5.4",            "variant": "xhigh" }
        ],
        "orchestratorPrompt": "@fixer-beta\n- Best-of-N variant of @fixer. Model: claude-opus-4-7 (Anthropic flagship lane for vendor diversity).\n- Dispatch ONLY via best-of-n-with-judge skill orchestration."
      },
      "fixer-gamma": {
        "model": "gauge-forge-openai/gpt-5.4",
        "variant": "xhigh",
        "orchestratorPrompt": "@fixer-gamma\n- Best-of-N variant of @fixer. Model: gpt-5.4 + xhigh reasoning effort (OpenAI deep-analysis lane).\n- Dispatch ONLY via best-of-n-with-judge skill orchestration."
      },
      "fixer-delta": {
        "model": "gauge-forge-openai/gpt-5.4-mini",
        "variant": "high",
        "orchestratorPrompt": "@fixer-delta\n- Best-of-N NAIVE CHALLENGER variant of @fixer. Model: gpt-5.4-mini (deliberate simple-baseline lane).\n- Dispatch ONLY via best-of-n-with-judge skill orchestration. Surfaces 'maybe the obvious simple thing is right' candidates that stronger variants overthink past."
      },

      "oracle-alpha": {
        "model": "gauge-forge-openai/gpt-5.5",
        "variant": "xhigh",
        "orchestratorPrompt": "@oracle-alpha\n- Best-of-N variant of @oracle. Model: gpt-5.5 + xhigh reasoning effort.\n- Dispatch ONLY via best-of-n-with-judge skill orchestration. Multi-candidate verdict format applies."
      },
      "oracle-beta": {
        "model": [
          { "id": "gauge-forge-anthropic/claude-opus-4-7", "variant": "high" },
          { "id": "gauge-forge-openai/gpt-5.4",            "variant": "xhigh" }
        ],
        "orchestratorPrompt": "@oracle-beta\n- Best-of-N variant of @oracle. Model: claude-opus-4-7 + high (Anthropic flagship review lane).\n- Dispatch ONLY via best-of-n-with-judge skill orchestration."
      },
      "oracle-gamma": {
        "model": "gauge-forge-openai/gpt-5.4",
        "variant": "xhigh",
        "orchestratorPrompt": "@oracle-gamma\n- Best-of-N variant of @oracle. Model: gpt-5.4 + xhigh reasoning effort (OpenAI alt-gen deep-analysis lane).\n- Dispatch ONLY via best-of-n-with-judge skill orchestration."
      },
      "oracle-delta": {
        "model": [
          { "id": "gauge-forge-anthropic/claude-sonnet-4-6", "variant": "high" },
          { "id": "gauge-forge-openai/gpt-5.4",            "variant": "medium" }
        ],
        "orchestratorPrompt": "@oracle-delta\n- Best-of-N variant of @oracle. Model: claude-sonnet-4-6 + high (Anthropic mid-tier diversity lane).\n- Dispatch ONLY via best-of-n-with-judge skill orchestration."
      },

      "designer-alpha": {
        "model": "gauge-forge-openai/gpt-5.5",
        "orchestratorPrompt": "@designer-alpha\n- Best-of-N variant of @designer. Model: gpt-5.5 (OpenAI flagship lane).\n- Dispatch ONLY via best-of-n-with-judge skill orchestration."
      },
      "designer-beta": {
        "model": [
          { "id": "gauge-forge-anthropic/claude-opus-4-7", "variant": "high" },
          { "id": "gauge-forge-openai/gpt-5.4",            "variant": "xhigh" }
        ],
        "orchestratorPrompt": "@designer-beta\n- Best-of-N variant of @designer. Model: claude-opus-4-7 (Anthropic flagship lane).\n- Dispatch ONLY via best-of-n-with-judge skill orchestration."
      },
      "designer-gamma": {
        "model": "gauge-forge-openai/gpt-5.4",
        "variant": "xhigh",
        "orchestratorPrompt": "@designer-gamma\n- Best-of-N variant of @designer. Model: gpt-5.4 + xhigh reasoning effort.\n- Dispatch ONLY via best-of-n-with-judge skill orchestration."
      },
      "designer-delta": {
        "model": [
          { "id": "gauge-forge-anthropic/claude-sonnet-4-6", "variant": "high" },
          { "id": "gauge-forge-openai/gpt-5.4",            "variant": "medium" }
        ],
        "orchestratorPrompt": "@designer-delta\n- Best-of-N variant of @designer. Model: claude-sonnet-4-6 (Anthropic mid-tier).\n- Dispatch ONLY via best-of-n-with-judge skill orchestration."
      },

      "explorer-alpha": {
        "model": "gauge-forge-openai/gpt-5.5",
        "variant": "high",
        "orchestratorPrompt": "@explorer-alpha\n- Variant of @explorer for best-of-N or ideation fan-out. Model: gpt-5.5 + high (primary recon lane).\n- Dispatch via best-of-n-with-judge ideation sub-mode or fan-out skill orchestration, not directly."
      },
      "explorer-beta": {
        "model": [
          { "id": "gauge-forge-anthropic/claude-sonnet-4-6", "variant": "high" },
          { "id": "gauge-forge-openai/gpt-5.4",            "variant": "medium" }
        ],
        "orchestratorPrompt": "@explorer-beta\n- Variant of @explorer for best-of-N or ideation fan-out. Model: claude-sonnet-4-6 + high (vendor-diverse recon lane).\n- Dispatch via best-of-n-with-judge ideation sub-mode or fan-out skill orchestration, not directly."
      },

      "librarian-alpha": {
        "model": [
          { "id": "gauge-forge-anthropic/claude-opus-4-7", "variant": "high" },
          { "id": "gauge-forge-openai/gpt-5.4",            "variant": "xhigh" }
        ],
        "mcps": ["websearch", "context7", "gh_grep"],
        "orchestratorPrompt": "@librarian-alpha\n- Variant of @librarian for best-of-N or ideation fan-out. Model: claude-opus-4-7 + high (primary research lane).\n- Dispatch via best-of-n-with-judge ideation sub-mode or fan-out skill orchestration, not directly."
      },
      "librarian-beta": {
        "model": "gauge-forge-openai/gpt-5.5",
        "variant": "high",
        "mcps": ["websearch", "context7", "gh_grep"],
        "orchestratorPrompt": "@librarian-beta\n- Variant of @librarian for best-of-N or ideation fan-out. Model: gpt-5.5 + high (vendor-diverse research lane).\n- Dispatch via best-of-n-with-judge ideation sub-mode or fan-out skill orchestration, not directly."
      },

      // ============ Fast-lane utility agents (4) ============
      // Latency-optimized narrow-scope agents. NOT in best-of-N pool.

      "scout": {
        "model": [
          { "id": "gauge-forge-anthropic/claude-haiku-4-5", "variant": "high" },
          { "id": "gauge-forge-openai/gpt-5.4-mini",            "variant": "medium" }
        ],
        "orchestratorPrompt": "@scout\n- Latency-optimized narrow lookup utility. Model: haiku-4-5.\n- Use for: 'which file contains X', 'what's at file:line', 'is there a Y anywhere'.\n- Returns 1-sentence answer with file:line, or 'REQUIRES_DEEPER_AGENT' if the question needs deep investigation.\n- Don't use for: race conditions, multi-repo correlation, subtle pattern matching. Dispatch @explorer instead."
      },
      "validator": {
        "model": "gauge-forge-openai/gpt-5.4-mini",
        "orchestratorPrompt": "@validator\n- Format and syntax checker. Model: gpt-5.4-mini.\n- Use for: 'is this valid JSON', 'does this YAML parse', 'is this regex syntactically valid'.\n- Returns VALID / INVALID / REQUIRES_DEEPER_AGENT. Does not propose fixes.\n- Don't use for: debugging deserialization, 'what's wrong with this regex'. Dispatch @oracle instead."
      },
      "gist": {
        "model": [
          { "id": "gauge-forge-anthropic/claude-haiku-4-5", "variant": "high" },
          { "id": "gauge-forge-openai/gpt-5.4-mini",            "variant": "medium" }
        ],
        "orchestratorPrompt": "@gist\n- Fast file/function summarizer. Model: haiku-4-5.\n- Use for: 'in 3 lines what does this file do', 'what is this function for', quick context retrieval before deep dive.\n- Returns 3-line summary or REQUIRES_DEEPER_AGENT.\n- Don't use for: design analysis, intent reasoning, quality critique. Dispatch @oracle instead."
      },
      "wildcard": {
        "model": "gauge-forge-openai/gpt-5.4-mini",
        "variant": "high",
        "orchestratorPrompt": "@wildcard\n- Divergent ideation contributor. Model: gpt-5.4-mini, temperature 1.0.\n- Use ONLY in brainstorming Phase 4 ideation fan-out alongside oracle/librarian/explorer/designer alpha-variants.\n- Proposes naive / contrarian / cross-domain / constraint-flipping ideas that domain experts overthink past.\n- DO NOT use for implementation, recon, or any task outside ideation."
      }
    }
  },
  "council": {
    "default_preset": "default",
    "councillor_execution_mode": "serial",
    "presets": {
      "default": {
        "alpha": {
          "model": "openai/gpt-5.4-mini",
          "variant": "high",
          "prompt": "You are a conservative review councillor. Prioritize correctness, scope control, and workflow preservation."
        },
        "beta": {
          "model": "openai/gpt-5.4-mini",
          "variant": "high",
          "prompt": "You are a contrarian review councillor. Look for hidden assumptions, integration risks, and reviewer blind spots."
        }
      }
    }
  }
}
